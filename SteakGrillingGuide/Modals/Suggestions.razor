@using MudBlazor
<div class="modal fade" id="suggestionsModal" tabindex="-1" aria-labelledby="suggestionsModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="suggestionsModalLabel">Before You Grill</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3 fw-bold">
                    Before you get started on your steaks, we have some suggestions for preparing and cooking your steak:
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        Make sure your grill is cleaned, the higher temperatures can cause the grease to catch fire.
                    </li>
                    <li class="list-group-item">
                        Sit steaks out at room temperature for 30 minutes prior to cooking
                    </li>
                    <li class="list-group-item">
                        Season steaks on both sides with favorite seasoning
                    </li>
                    <li class="list-group-item">
                        Pre heat grill to approximately 500 degrees
                    </li>
                    <li class="list-group-item">
                        Let steaks rest for 5 minutes after grilling prior to eating.
                    </li>
                    <li class="list-group-item">
                        Verify steaks are properly cooked before eating.
                    </li>
                    <li class="list-group-item">
                        Enjoy!
                    </li>
                </ul>
                <div>
                    <MudCheckBox Value="DontShowOnStart" ValueChanged="((bool value)=> ShowDialogPreferenceChanged(value))">Do not show on start up.</MudCheckBox>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>