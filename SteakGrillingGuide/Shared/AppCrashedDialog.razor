@using MudBlazor;

<MudDialog>
    <DialogContent>
        <h5>Uh oh!</h5>
        @if (BeforeFinish)
        {
            <div>
                It looks like the app closed unexpectedion. We have saved your information before the app closed and it looks like there is still time remaining. Would you like to restore and start the timer?
            </div>
        }
        else
        {
            <div>
                It looks like the app closed unexpectedion. We have saved your information before the app closed, but the time for when the steaks would finish has passed. Would you like to restore just the steaks?
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined">No</MudButton>
        <MudButton Color="@Color.Success" Variant="Variant.Outlined" OnClick="Submit">Yes</MudButton>
    </DialogActions>
</MudDialog>